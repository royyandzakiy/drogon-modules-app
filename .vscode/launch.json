{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug Drogon App (CMake)",
			"type": "cppvsdbg",
			"request": "launch",
			"program": "${command:cmake.launchTargetPath}",
			"args": [],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [
				{
					"name": "PATH",
					"value": "${env:PATH};C:/vcpkg/installed/x64-windows/bin"
				}
			],
			"console": "integratedTerminal"
		}
	]
}