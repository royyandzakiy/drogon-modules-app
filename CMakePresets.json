{
	"version": 3,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 20,
		"patch": 0
	},
	"configurePresets": [
		{
			"name": "base",
			"description": "Abstract base for directory structure",
			"hidden": true,
			"binaryDir": "${sourceDir}/build/${presetName}"
		},
		{
			"name": "windows-vcpkg-base",
			"description": "Common Windows settings for MSVC and vcpkg",
			"hidden": true,
			"inherits": "base",
			"generator": "Visual Studio 17 2022",
			"architecture": {
				"value": "x64",
				"strategy": "external"
			},
			"cacheVariables": {
				"CMAKE_TOOLCHAIN_FILE": "C:/vcpkg/scripts/buildsystems/vcpkg.cmake",
				"CMAKE_CXX_EXTENSIONS": "OFF",
				"CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/bin"
			},
			"vendor": {
				"microsoft.com/VisualStudioSettings/CMake/1.0": {
					"hostOS": [
						"Windows"
					]
				}
			}
		},
		{
			"name": "windows-debug",
			"description": "Targeting Windows x64 Debug",
			"inherits": "windows-vcpkg-base",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug"
			}
		},
		{
			"name": "windows-release",
			"description": "Targeting Windows x64 Release",
			"inherits": "windows-vcpkg-base",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release"
			}
		}
	],
	"buildPresets": [
		{
			"name": "base-build",
			"hidden": true,
			"inheritConfigureEnvironment": true
		},
		{
			"name": "debug",
			"inherits": "base-build",
			"configurePreset": "windows-debug",
			"configuration": "Debug"
		},
		{
			"name": "release",
			"inherits": "base-build",
			"configurePreset": "windows-release",
			"configuration": "Release"
		},
		{
			"name": "release-clean",
			"inherits": "release",
			"cleanFirst": true
		}
	],
	"testPresets": [
		{
			"name": "base-test",
			"hidden": true,
			"output": {
				"outputOnFailure": true
			}
		},
		{
			"name": "test-debug",
			"inherits": "base-test",
			"configurePreset": "windows-debug"
		},
		{
			"name": "test-release",
			"inherits": "base-test",
			"configurePreset": "windows-release"
		}
	]
}